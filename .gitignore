# used to configure VS Code settings
!.vscode

# Outputs
**/runs/*
**/logs/*
**/recordings/*
**/output/*
**/outputs/*
**/videos/*
**/wandb/*
**/.neptune/*
docker/artifacts/
*.tmp
logs
outputs

# Isaac-Sim packman
_isaac_sim*
_repo
_build
.lastformat

# ----------------------------------------------------------------------
# InstinctLab training/eval artifacts (safe to skip pushing)
# ----------------------------------------------------------------------
# Checkpoints / exported models
*.pt
*.pth
*.ckpt
*.onnx
*.engine

# TensorBoard / Hydra / experiment metadata
**/events.out.tfevents*
**/.hydra/
tensorboard/

# Parkour eval outputs generated by play.py --eval_mode
source/instinctlab/instinctlab/tasks/parkour/scripts/eval/*

# Local archives and temp files
source/instinctlab/*.zip
*.bak
